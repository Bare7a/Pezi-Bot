  "author": "Bare7a <bare7a@gmail.com> (http://github.com/Bare7a)",
  "homepage": "https://github.com/Pezi-Bot/Pezi-Bot",
  "description": "Twitch Chat bot designed to enhance your viewers' experience by providing a fun and engaging environment for them to interact in.",
  "keywords": [
    "twitch",
    "chatbot",
    "bot",
    "minigames",
    "mini",
    "games"
  ],
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "export": "npm run export -w @pezi-bot/bot",
    "import": "npm run import -w @pezi-bot/bot",
    "build:db": "npm run build -w @pezi-bot/db",
    "dev:bot": "npm run dev -w @pezi-bot/bot",
    "build:bot": "npm run build -w @pezi-bot/bot",
    "start:bot": "npm run start -w @pezi-bot/bot",
    "dev:web": "npm run dev -w @pezi-bot/web",
    "build:web": "npm run build -w @pezi-bot/web",
    "start:web": "npm run start -w @pezi-bot/web"
  },
  "dependencies": {
    "@pezi-bot/bot": "^1.0.2",
    "@pezi-bot/db": "^1.0.2"
  }
}
